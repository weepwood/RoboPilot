<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robopilot">
  <xacro:property name="base_length" value="0.38"/>
  <xacro:property name="base_width" value="0.30"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="wheel_radius" value="0.065"/>
  <xacro:property name="wheel_width" value="0.040"/>
  <xacro:property name="wheel_separation" value="0.34"/>

  <material name="body_blue">
    <color rgba="0.12 0.43 0.78 1.0"/>
  </material>
  <material name="dark">
    <color rgba="0.08 0.10 0.13 1.0"/>
  </material>
  <material name="sensor">
    <color rgba="0.94 0.34 0.20 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.11" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.050" ixy="0" ixz="0" iyy="0.075" iyz="0" izz="0.105"/>
    </inertial>
  </link>

  <xacro:macro name="drive_wheel" params="side y_value">
    <link name="${side}_wheel_link">
      <visual>
        <origin rpy="1.570796 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin rpy="1.570796 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="1.570796 0 0"/>
        <mass value="0.45"/>
        <inertia ixx="0.00055" ixy="0" ixz="0" iyy="0.00055" iyz="0" izz="0.00030"/>
      </inertial>
    </link>

    <joint name="${side}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${side}_wheel_link"/>
      <origin xyz="0 ${y_value} -0.045" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.05" friction="0.02"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel side="left" y_value="${wheel_separation / 2.0}"/>
  <xacro:drive_wheel side="right" y_value="${-wheel_separation / 2.0}"/>

  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="0.026"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.026"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.145 0 -0.078"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.055" length="0.045"/>
      </geometry>
      <material name="sensor"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.055" length="0.045"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.18"/>
      <inertia ixx="0.00018" ixy="0" ixz="0" iyy="0.00018" iyz="0" izz="0.00025"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.09 0 0.095"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.1</mu1>
    <mu2>1.1</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.1</mu1>
    <mu2>1.1</mu2>
  </gazebo>
  <gazebo reference="caster_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.02</mu1>
    <mu2>0.02</mu2>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="front_lidar" type="gpu_lidar">
      <topic>/scan</topic>
      <update_rate>12</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <pose>0 0 0.03 0 0 0</pose>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.1415926</min_angle>
            <max_angle>3.1415926</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.008</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>
</robot>
